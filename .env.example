# ============================================================
# Resume AI — Complete Environment Variables Reference
# ============================================================
# This file lists ALL environment variables for both
# the backend (Render) and frontend (Vercel).
# Copy the relevant sections when configuring each service.
# ============================================================


# ════════════════════════════════════════════════════════════
#  BACKEND (Render)
# ════════════════════════════════════════════════════════════

# Application environment: "development" or "production"
ENVIRONMENT=production

# The deployed frontend URL for CORS (e.g. https://your-app.vercel.app)
FRONTEND_URL=https://your-app.vercel.app

# Primary AI Provider: gemini, groq, or openrouter
AI_PROVIDER=gemini

# Gemini API Key — https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key — https://console.groq.com/
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter API Key — https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# Max upload file size in bytes (default: 5MB)
MAX_FILE_SIZE=5242880

# ── Authentication & Database ───────────────────────────
DATABASE_URL=sqlite:///./resumeai.db
GOOGLE_CLIENT_ID=your_google_client_id_here
JWT_SECRET=generate_a_secure_random_string_for_production
ADMIN_EMAILS=admin@example.com,owner@example.com

# Server port (Render sets this automatically — do NOT set manually)
# PORT=10000

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO


# ════════════════════════════════════════════════════════════
#  FRONTEND (Vercel)
# ════════════════════════════════════════════════════════════

# Backend API URL — your Render service URL
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
