docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this is usually fine to prevent caching.
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if you want to share your dependency lock file,
#   you should commit it. But if you want to keep lock file local, uncomment:
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally committed, but can be ignored.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally committed, but can be ignored.
#.pdm.toml
.pdm-plugins/

# venv
#   Recommended to not commit virtual environments into git repo
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static analyzer
.pytype/

# Cython debug symbols
cython_debug/

# OS metadata
.DS_Store
Thumbs.db

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Frontend build directories
frontend/dist/
frontend/build/

# Local env files
.env*.local
.env
