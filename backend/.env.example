# Resume AI - Backend Configuration

# ── Environment ─────────────────────────────────────────
# Set to "production" on Render, "development" locally
ENVIRONMENT=development

# ── CORS / Frontend URL ────────────────────────────────
# The deployed frontend URL (e.g. https://your-app.vercel.app)
# Required in production so the backend allows cross-origin requests
FRONTEND_URL=

# ── AI Provider ─────────────────────────────────────────
# Primary AI Provider: gemini, groq, or openrouter
AI_PROVIDER=gemini

# Get your Gemini API Key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Get your Groq API Key from Groq Console: https://console.groq.com/
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Get your OpenRouter API Key from OpenRouter: https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# ── File Uploads ────────────────────────────────────────
# Max allowed resume upload file size in bytes (default: 5MB)
MAX_FILE_SIZE=5242880

# ── Authentication & Database ───────────────────────────
DATABASE_URL=sqlite:///./resumeai.db
GOOGLE_CLIENT_ID=your_google_client_id_here
JWT_SECRET=generate_a_secure_random_string_for_production
ADMIN_EMAILS=admin@example.com,owner@example.com

# ── Server ──────────────────────────────────────────────
# Port for backend FastAPI server (Render sets this automatically)
PORT=8000

# ── Logging ─────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
